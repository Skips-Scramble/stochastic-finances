{
    "terminal.integrated.cwd": "${workspaceFolder}",
    "mcp": {
        "servers": {
            "github": {
                "command": "npx",
                "args": [
                    "-y",
                    "@modelcontextprotocol/server-github"
                ],
                "env": {
                    "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_PERSONAL_ACCESS_TOKEN}"
                }
            },
            "git": {
                "command": "uvx",
                "args": [
                    "mcp-server-git",
                    "--repository",
                    "${workspaceFolder}"
                ]
            }
        }
    }
}
